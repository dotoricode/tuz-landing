# ---- Site ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Payload ----
PAYLOAD_SECRET=replace-with-long-random-string
REVALIDATE_SECRET=replace-with-long-random-string

# ---- Database (Supabase Postgres) ----
# Use the Session Pooler connection string from the Supabase dashboard.
DATABASE_URI=postgres://postgres.<ref>:<password>@<host>:5432/postgres

# ---- Media storage (Supabase Storage, S3-compatible) ----
# Leave blank to disable S3 storage adapter (uploads fall back to local /media).
S3_BUCKET=tuz-media
S3_ENDPOINT=https://<ref>.supabase.co/storage/v1/s3
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto
